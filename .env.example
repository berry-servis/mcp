MEDUSA_BACKEND_URL=https://api.berryservis.cz
MEDUSA_OFFICE_PUBLISHABLE_KEY=
PORT=3000

# Optional: product handles used by group orders (defaults shown)
MEDUSA_STRAWBERRY_HANDLE=jahodovy-box
# MEDUSA_MINI_JAM_HANDLE=   # set to enable the jam add-on in place_group_order

# Google Calendar (public "B2B - offices" calendar) - open delivery Tuesdays.
# Optional: unset = fall back to the season-Tuesday window.
GOOGLE_CALENDAR_API_KEY=
GOOGLE_CALENDAR_ID=

# Sentry error capture (optional; init is a no-op when SENTRY_DSN is unset)
SENTRY_DSN=
SENTRY_ENVIRONMENT=
